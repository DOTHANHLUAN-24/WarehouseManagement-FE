<MudMenu AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">

    <ActivatorContent>
        <MudAvatar Size="Size.Small" Style="cursor:pointer">
            <MudImage Src="https://images.unsplash.com/photo-1769708526549-05310c4ade1d?q=80&w=685&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" />
        </MudAvatar>
    </ActivatorContent>

    <ChildContent>
        <MudMenuItem OnClick="@(() => Console.WriteLine("Profile clicked"))">
            Profile
        </MudMenuItem>

        <MudMenuItem OnClick="@(() => Console.WriteLine("Theme clicked"))">
            Theme
        </MudMenuItem>

        <MudMenuItem OnClick="Logout">
            Logout
        </MudMenuItem>
    </ChildContent>

</MudMenu>

@code {
    [Parameter]
    public string UserName { get; set; } = "Admin";

    void Logout()
    {
        Console.WriteLine("Logout clicked");
    }
}