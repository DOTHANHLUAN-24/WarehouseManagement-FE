@inherits LayoutComponentBase

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>

    <!-- Sidebar -->
    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Mini"
               Elevation="1">

        <NavMenu />

    </MudDrawer>


    <!-- Main -->
    <MudMainContent>

        <MudAppBar Elevation="1" Fixed="true">

            <!-- Toggle sidebar -->
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           OnClick="ToggleDrawer" />

            <MudText Typo="Typo.h6" Class="ml-2">
                Warehouse Management
            </MudText>

            <MudSpacer />

            <MudIconButton Icon="@Icons.Material.Filled.Notifications" />

            <UserMenu UserName="Admin"></UserMenu>

        </MudAppBar>


        <MudContainer Class="mt-6">

            <MudPaper Class="pa-6">
                @Body
            </MudPaper>

        </MudContainer>

    </MudMainContent>

</MudLayout>


@code {

    private bool _drawerOpen = true;

    void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

}